# Public frontend environment variables
# Fill these from the Supabase dashboard. Publishable keys are browser-safe,
# but keeping live project values out of git makes rotation and environment separation easier.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
# Optional legacy fallback only when your project still uses anon JWT keys.
VITE_SUPABASE_ANON_KEY=

# Server-only Netlify Function variables. Never prefix provider keys with VITE_.
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=your_openrouter_server_key
OPENROUTER_MODEL=tencent/hy3

# Optional provider fallbacks
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Beta safeguards
AI_DAILY_USER_LIMIT=25
AI_MAX_MESSAGES=16
AI_MAX_PROMPT_CHARS=12000
AI_MAX_OUTPUT_TOKENS=1800
PUBLIC_SITE_URL=https://nibras-tutor.netlify.app
ALLOWED_ORIGIN=https://nibras-tutor.netlify.app
